[
  {
    "capability": "lightweight-lint-single-file",
    "constraints": [
      "bundled in this package under linter-cli/",
      "run npm install and npm run install-runtime-deps before first use",
      "input is a single pure non-UI .ets file",
      "checker diagnostics only; no .abc generation or runtime execution"
    ],
    "command_template": "cd linter-cli && node ./bin/linter-cli.js --input /abs/path/file.ets",
    "usage_intent": [
      "validation",
      "debugging",
      "review",
      "authoring"
    ]
  },
  {
    "capability": "check-single-file",
    "constraints": [
      "input only supports pure non-UI .ets",
      "single entry file"
    ],
    "command_template": "cd arkts-cli && node ./bin/arkts-cli.js --input /abs/path/file.ets --out-dir /abs/path/out",
    "usage_intent": [
      "validation",
      "authoring",
      "review"
    ]
  },
  {
    "capability": "check-run-project",
    "constraints": [
      "input only supports pure non-UI .ets",
      "entry must live under --input-dir in multi-file mode"
    ],
    "command_template": "cd arkts-cli && node ./bin/arkts-cli.js --input /abs/path/main.ets --input-dir /abs/path/src --out-dir /abs/path/out --run",
    "usage_intent": [
      "run",
      "validation",
      "debugging"
    ]
  },
  {
    "capability": "snippet-validation",
    "constraints": [
      "currently focused on 02-Basic-Syntax",
      "expects markdown fenced code blocks tagged as typescript"
    ],
    "command_template": "python3 ./tools/snippets_cli.py test --scope 02-Basic-Syntax --file advanced-operators.md",
    "usage_intent": [
      "testing",
      "validation",
      "debugging"
    ]
  }
]
