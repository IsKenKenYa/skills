    "napi_mapping_patterns": {
      "description": "NAPI 映射模式说明",
      "patterns": [
        {
          "pattern": "Promise 回调模式",
          "description": "异步操作使用 Promise，通过 napi_create_promise 创建，napi_resolve_deferred/napi_reject_deferred 完成",
          "example": "FetchBySession, SetCookies, GetCookies"
        },
        {
          "pattern": "同步返回模式",
          "description": "同步操作直接返回结果，使用 NapiUtils 创建返回值",
          "example": "GenerateRequestId, GenerateSessionId, HasPermission"
        },
        {
          "pattern": "参数验证模式",
          "description": "使用 napi_get_cb_info 获取参数，通过 NapiUtils 验证类型和值",
          "example": "所有 NAPI 函数"
        },
        {
          "pattern": "错误处理模式",
          "description": "使用 ThrowNapiError 抛出错误，或通过 CreateNapiRcpError 创建错误对象",
          "example": "FetchBySession, GetError"
        },
        {
          "pattern": "线程安全模式",
          "description": "使用 napi_threadsafe_function 在不同线程间安全调用回调",
          "example": "MakePromiseCallback, MakeSetCookiesCallback, MakeGetCookiesCallback"
        }
      ]
    }
  }
  